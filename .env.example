# BioStack — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION: Copy to .env, fill every "Required" value, NEVER commit .env
# DEVELOPMENT: Copy to .env, keep ASPNETCORE_ENVIRONMENT=Development,
#              leave Smtp__Host blank to use in-memory magic link inbox.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=                          # Required (prod). Strong random password for PostgreSQL.
                                      # Dev default handled in docker-compose.dev.yml.

# ── Backend runtime ───────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production     # Production | Development
ASPNETCORE_URLS=http://+:5000

# Production: postgres connection string (required when ASPNETCORE_ENVIRONMENT=Production)
# ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=biostack;Username=biostack;Password=<DB_PASSWORD>
# Dev SQLite fallback (docker-compose.dev.yml sets this automatically):
# ConnectionStrings__DefaultConnection=Data Source=/app/data/biostack.db

# ── Secrets — REQUIRED IN PRODUCTION ─────────────────────────────────────────
# Generate each with: openssl rand -hex 32
Jwt__Secret=                          # Required. Min 32 chars. Signs JWT bearer tokens.
Auth__CallbackSecret=                 # Required. Shared secret between API ↔ frontend.
                                      # Must match AUTH_CALLBACK_SECRET in frontend vars.

Jwt__Issuer=biostack
Jwt__Audience=biostack-ui
Jwt__ExpiryMinutes=60

# ── Public URLs ───────────────────────────────────────────────────────────────
PublicApiUrl=https://api.yourdomain.com   # Production API base URL
FrontendUrl=https://yourdomain.com        # Production frontend base URL
# Dev: PublicApiUrl=http://localhost:5000 / FrontendUrl=http://localhost:3043

# ── Email delivery (choose Option A or B; leave both blank for dev inbox) ────
# Option A: SMTP
Smtp__Host=                           # e.g. smtp.sendgrid.net — leave blank in dev
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=noreply@yourdomain.com
Smtp__FromName=BioStack
Smtp__MagicLinkSubject=Your BioStack sign-in link

# Option B: Azure Communication Services Email (takes priority over SMTP when set)
# AzureCommunicationEmail__ConnectionString=

# ── Frontend (NextAuth v5) ────────────────────────────────────────────────────
# These go into frontend/.env.local (or Docker build args / container env)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
API_INTERNAL_URL=http://biostack-api:5000   # Internal Docker network — no change needed
AUTH_SECRET=                          # Required. Min 32 chars. Generate: openssl rand -hex 32
AUTH_URL=https://yourdomain.com       # Required. Public frontend URL.
AUTH_TRUST_HOST=true
AUTH_CALLBACK_SECRET=                 # Required. Must match Auth__CallbackSecret above.

# ── OAuth providers (all optional — leave blank to disable) ──────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=

# ── Stripe (optional — billing features) ─────────────────────────────────────
Stripe__SecretKey=
Stripe__WebhookSecret=
Stripe__OperatorPriceId=
Stripe__CommanderPriceId=
Stripe__CheckoutSuccessUrl=https://yourdomain.com/billing?checkout=success
Stripe__CheckoutCancelUrl=https://yourdomain.com/billing?checkout=cancelled
Stripe__PortalReturnUrl=https://yourdomain.com/billing

# ── Redis (optional — falls back to in-memory cache) ─────────────────────────
# Redis__Configuration=your-redis-host:6379
# Redis__InstanceName=biostack:

# ── Knowledge worker (one-shot seeding job) ───────────────────────────────────
Worker__RunMode=Seed                  # Seed | Analyze | Both
Worker__DryRun=false
Worker__MaxBatchSize=50

# ── Docker / Hot Reload (dev-only) ───────────────────────────────────────────
# CHOKIDAR_USEPOLLING=true
# WATCHPACK_POLLING=true
# DOTNET_USE_POLLING_FILE_WATCHER=1
