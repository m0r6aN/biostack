# BioStack Mission Control - Environment Configuration

# ── Backend ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
ConnectionStrings__DefaultConnection=Data Source=/app/data/biostack.db

# JWT (backend-issued tokens)
Jwt__Secret=CHANGE_ME_MINIMUM_32_CHARACTER_RANDOM_STRING
Jwt__Issuer=biostack
Jwt__Audience=biostack-ui
Jwt__ExpiryMinutes=60

# Public URLs used when building and completing magic links
PublicApiUrl=http://localhost:5000
FrontendUrl=http://localhost:3043

# SMTP delivery for production magic link emails. Leave Smtp__Host empty in
# local development to use /dev/auth/inbox instead of sending real email.
Smtp__Host=
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=no-reply@example.com
Smtp__FromName=BioStack
Smtp__MagicLinkSubject=Your BioStack sign-in link

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NODE_ENV=development

# ── Docker / Hot Reload ───────────────────────────────────────────────────────
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
DOTNET_USE_POLLING_FILE_WATCHER=1
