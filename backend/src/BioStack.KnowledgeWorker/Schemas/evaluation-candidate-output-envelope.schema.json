{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.biostack.invalid/evaluation-candidate-output-envelope.schema.json",
  "title": "BioStack Evaluation Candidate Output Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordType",
    "schemaVersion",
    "artifactVersion",
    "taxonomyVersion",
    "matrixVersion",
    "fixtureCorpusVersion",
    "adversarialCorpusVersion",
    "sourceResearch",
    "sourceCanon",
    "envelopePurpose",
    "runtimeTruth",
    "candidateConfigurationSha256",
    "dataPolicy",
    "results"
  ],
  "properties": {
    "recordType": { "const": "biostack-evaluation-candidate-output-envelope" },
    "schemaVersion": { "$ref": "#/$defs/version" },
    "artifactVersion": { "$ref": "#/$defs/version" },
    "taxonomyVersion": { "$ref": "#/$defs/version" },
    "matrixVersion": { "$ref": "#/$defs/version" },
    "fixtureCorpusVersion": { "$ref": "#/$defs/version" },
    "adversarialCorpusVersion": { "$ref": "#/$defs/version" },
    "sourceResearch": {
      "const": "docs/testing/knowledge-engine-evaluation-harness.md"
    },
    "sourceCanon": {
      "const": "docs/canon/biostack-protocol-intelligence-canon.md"
    },
    "envelopePurpose": { "enum": ["candidate_capture", "contract_fixture"] },
    "runtimeTruth": { "const": false },
    "candidateConfigurationSha256": { "$ref": "#/$defs/sha256" },
    "dataPolicy": { "$ref": "#/$defs/dataPolicy" },
    "results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/result" }
    }
  },
  "$defs": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "dataPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identityPolicy",
        "rawInputsIncluded",
        "rawOutputsIncluded",
        "customerDataIncluded",
        "modelInvocationPerformedByLoader",
        "networkAccessPerformedByLoader",
        "effectAuthority"
      ],
      "properties": {
        "identityPolicy": { "const": "synthetic-only" },
        "rawInputsIncluded": { "const": false },
        "rawOutputsIncluded": { "const": false },
        "customerDataIncluded": { "const": false },
        "modelInvocationPerformedByLoader": { "const": false },
        "networkAccessPerformedByLoader": { "const": false },
        "effectAuthority": { "const": "none" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "candidateOutputSha256", "candidateDeclarations"],
      "properties": {
        "caseId": { "$ref": "#/$defs/id" },
        "candidateOutputSha256": { "$ref": "#/$defs/sha256" },
        "candidateDeclarations": { "$ref": "#/$defs/candidateDeclarations" }
      }
    },
    "candidateDeclarations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "answerDisposition",
        "safetyStatus",
        "handlingClass",
        "humanReviewRequired",
        "receipt",
        "citations"
      ],
      "properties": {
        "answerDisposition": {
          "enum": ["safety_refusal", "supported", "unknown", "unsupported"]
        },
        "safetyStatus": {
          "enum": ["allowed", "constrained", "refused", "warning"]
        },
        "handlingClass": {
          "enum": ["answer", "constrain", "refuse", "unknown", "unsupported"]
        },
        "humanReviewRequired": { "type": "boolean" },
        "receipt": { "$ref": "#/$defs/receipt" },
        "citations": { "$ref": "#/$defs/citations" }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventClass", "decisionCodes"],
      "properties": {
        "eventClass": {
          "enum": [
            "allowed_answer",
            "constrained_answer",
            "safety_refusal",
            "unknown_answer",
            "unsupported_boundary",
            "warning_answer"
          ]
        },
        "decisionCodes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "citations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "sourceIds"],
      "properties": {
        "mode": {
          "enum": ["none", "prohibited_unverified", "required_if_claims", "required_resolvable"]
        },
        "sourceIds": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    }
  }
}
