{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biostack.cc/schemas/review-decision.schema.json",
  "title": "BioStack Research Review Decision Batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "batch", "decisions"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "recordType": { "type": "string", "const": "review-decision-batch" },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batchId", "reviewerId", "reviewedAt", "notes"],
      "properties": {
        "batchId": { "type": "string", "minLength": 1 },
        "reviewerId": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    },
    "decisions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/decision" } }
  },
  "$defs": {
    "stringArray": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decisionId", "compoundName", "decision", "reviewerId", "reviewedAt", "scope", "notes"],
      "properties": {
        "decisionId": { "type": "string", "minLength": 1 },
        "compoundName": { "type": "string", "minLength": 1 },
        "decision": { "type": "string", "enum": ["approve-for-promotion", "approve-claims", "resolve-review-items", "archive-draft", "request-changes", "reject"] },
        "reviewerId": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claimIds", "qualityFlags", "reviewCategories", "promotionBlockers"],
          "properties": {
            "claimIds": { "$ref": "#/$defs/stringArray" },
            "reviewQueueItemIds": { "$ref": "#/$defs/stringArray" },
            "qualityFlags": { "$ref": "#/$defs/stringArray" },
            "reviewCategories": { "$ref": "#/$defs/stringArray" },
            "promotionBlockers": { "$ref": "#/$defs/stringArray" }
          }
        },
        "clearsSoftPromotionBlockers": { "type": "boolean", "default": false },
        "expiresAt": { "type": ["string", "null"], "format": "date-time" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    }
  }
}