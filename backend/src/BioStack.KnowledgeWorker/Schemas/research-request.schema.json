{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biostack.cc/schemas/research-request.schema.json",
  "title": "BioStack Research Request Batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "batch", "requests"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "recordType": { "type": "string", "const": "research-request-batch" },
    "batch": { "$ref": "#/$defs/batch" },
    "requests": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/request" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batchId", "requesterId", "requestedAt", "notes"],
      "properties": {
        "batchId": { "$ref": "#/$defs/nonEmptyString" },
        "requesterId": { "$ref": "#/$defs/nonEmptyString" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId", "compoundName", "aliases", "classification", "priority", "requesterId", "requestedAt", "rationale", "notes"],
      "properties": {
        "requestId": { "$ref": "#/$defs/nonEmptyString" },
        "compoundName": { "$ref": "#/$defs/nonEmptyString" },
        "aliases": { "$ref": "#/$defs/stringArray" },
        "classification": { "$ref": "#/$defs/nonEmptyString" },
        "priority": { "type": "string", "enum": ["low", "normal", "high", "urgent"] },
        "requesterId": { "$ref": "#/$defs/nonEmptyString" },
        "requestedAt": { "type": "string", "format": "date-time" },
        "rationale": { "$ref": "#/$defs/nonEmptyString" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    }
  }
}