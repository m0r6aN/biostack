{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biostack.cc/schemas/compound-candidate.schema.json",
  "title": "BioStack Compound Candidate Batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "batch", "candidates"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "recordType": { "type": "string", "const": "compound-candidate-batch" },
    "batch": { "$ref": "#/$defs/batch" },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "score": { "type": "integer", "minimum": 0, "maximum": 5 },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batchId", "category", "generatedAt", "agentId", "notes"],
      "properties": {
        "batchId": { "$ref": "#/$defs/nonEmptyString" },
        "category": { "$ref": "#/$defs/nonEmptyString" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "agentId": { "$ref": "#/$defs/nonEmptyString" },
        "notes": { "$ref": "#/$defs/stringArray" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalNameCandidate",
        "aliases",
        "category",
        "classification",
        "inclusionRationale",
        "prioritySignals",
        "discoverySources",
        "reviewFlags"
      ],
      "properties": {
        "canonicalNameCandidate": { "$ref": "#/$defs/nonEmptyString" },
        "aliases": { "$ref": "#/$defs/stringArray" },
        "brandNames": { "$ref": "#/$defs/stringArray" },
        "category": { "$ref": "#/$defs/nonEmptyString" },
        "classification": {
          "type": "string",
          "enum": [
            "Peptide",
            "Small Molecule",
            "Biologic",
            "Hormone",
            "SARM",
            "SERM",
            "Vitamin",
            "Mineral",
            "Supplement",
            "Pharmaceutical",
            "Amino Acid",
            "Research Compound",
            "Botanical",
            "Other"
          ]
        },
        "compoundFamily": { "type": ["string", "null"] },
        "inclusionRationale": { "$ref": "#/$defs/nonEmptyString" },
        "prioritySignals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["popularity", "emergingInterest", "clinicalRelevance", "safetyRisk", "misinformationRisk", "sourceAvailability"],
          "properties": {
            "popularity": { "$ref": "#/$defs/score" },
            "emergingInterest": { "$ref": "#/$defs/score" },
            "clinicalRelevance": { "$ref": "#/$defs/score" },
            "safetyRisk": { "$ref": "#/$defs/score" },
            "misinformationRisk": { "$ref": "#/$defs/score" },
            "sourceAvailability": { "$ref": "#/$defs/score" }
          }
        },
        "externalIdentifiers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rxnorm", "unii", "casNumber", "drugbank", "pubchem", "chembl"],
          "properties": {
            "rxnorm": { "type": ["string", "null"] },
            "unii": { "type": ["string", "null"] },
            "casNumber": { "type": ["string", "null"] },
            "drugbank": { "type": ["string", "null"] },
            "pubchem": { "type": ["string", "null"] },
            "chembl": { "type": ["string", "null"] }
          }
        },
        "discoverySources": { "$ref": "#/$defs/stringArray" },
        "reviewFlags": { "$ref": "#/$defs/stringArray" }
      }
    }
  }
}