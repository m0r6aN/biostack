{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biostack.local/schemas/evaluation-coverage-matrix.schema.json",
  "title": "BioStack Evaluation Coverage Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordType",
    "schemaVersion",
    "artifactVersion",
    "taxonomyVersion",
    "sourceResearch",
    "runtimeTruth",
    "ownerAssignmentState",
    "coverageCases",
    "requiredValuePairs"
  ],
  "properties": {
    "recordType": { "const": "biostack-evaluation-coverage-matrix" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "artifactVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "taxonomyVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "sourceResearch": { "type": "string", "minLength": 1 },
    "runtimeTruth": { "const": false },
    "ownerAssignmentState": { "const": "pending-human-assignment" },
    "coverageCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "ownerRoleId", "fixture", "selections", "expected"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "ownerRoleId": { "$ref": "#/$defs/pendingRoleId" },
          "fixture": {
            "type": "object",
            "additionalProperties": false,
            "required": ["request", "expectedBehavior"],
            "properties": {
              "request": { "type": "string", "minLength": 1 },
              "expectedBehavior": { "type": "string", "minLength": 1 }
            }
          },
          "selections": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": { "$ref": "#/$defs/id" }
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["answerDisposition", "safetyStatus", "humanReviewRequired"],
            "properties": {
              "answerDisposition": { "$ref": "#/$defs/id" },
              "safetyStatus": { "$ref": "#/$defs/id" },
              "humanReviewRequired": { "type": "boolean" }
            }
          }
        }
      }
    },
    "requiredValuePairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "left", "right", "coveredByCaseId"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "left": { "$ref": "#/$defs/selection" },
          "right": { "$ref": "#/$defs/selection" },
          "coveredByCaseId": { "$ref": "#/$defs/id" }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "pendingRoleId": {
      "type": "string",
      "pattern": "^role:pending:[a-z0-9][a-z0-9-]*$"
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimensionId", "valueId"],
      "properties": {
        "dimensionId": { "$ref": "#/$defs/id" },
        "valueId": { "$ref": "#/$defs/id" }
      }
    }
  }
}
