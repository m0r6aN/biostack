{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biostack.cc/schemas/source-registry.schema.json",
  "title": "BioStack Governed Research Source Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "recordType", "generatedAt", "agentId", "sources"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "recordType": { "type": "string", "const": "source-registry" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "agentId": { "$ref": "#/$defs/nonEmptyString" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nullableString": { "type": ["string", "null"] },
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity",
        "rights",
        "operations",
        "acquisition",
        "evidencePolicy",
        "provenanceRequirements",
        "refreshPolicy",
        "remediation",
        "dataBoundary"
      ],
      "properties": {
        "identity": { "$ref": "#/$defs/identity" },
        "rights": { "$ref": "#/$defs/rights" },
        "operations": { "$ref": "#/$defs/operations" },
        "acquisition": { "$ref": "#/$defs/acquisition" },
        "evidencePolicy": { "$ref": "#/$defs/evidencePolicy" },
        "provenanceRequirements": { "$ref": "#/$defs/provenanceRequirements" },
        "refreshPolicy": { "$ref": "#/$defs/refreshPolicy" },
        "remediation": { "$ref": "#/$defs/remediation" },
        "dataBoundary": { "$ref": "#/$defs/dataBoundary" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "acquisition": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            },
            "required": ["acquisition"]
          },
          "then": {
            "properties": {
              "rights": {
                "properties": {
                  "reviewStatus": { "const": "approved" },
                  "legalBasisOrLicense": { "type": "string", "minLength": 1 },
                  "termsUrl": { "type": "string", "format": "uri", "minLength": 1 },
                  "verifiedAtUtc": { "type": "string", "format": "date-time" },
                  "allowedUses": { "type": "array", "minItems": 1 },
                  "reviewedByRole": { "type": "string", "minLength": 1 }
                }
              },
              "operations": {
                "properties": {
                  "status": { "const": "active" },
                  "ownerRole": { "type": "string", "minLength": 1 },
                  "securityOwnerRole": { "type": "string", "minLength": 1 },
                  "lastReviewedAtUtc": { "type": "string", "format": "date-time" }
                }
              },
              "acquisition": {
                "properties": {
                  "method": { "enum": ["api", "bulk-download", "manual-review", "licensed-feed", "other"] },
                  "robotsPolicyStatus": { "enum": ["approved", "not-applicable"] },
                  "apiTermsStatus": { "enum": ["approved", "not-applicable"] },
                  "rateLimitPolicy": { "type": "string", "minLength": 1 },
                  "accessNotes": { "type": "string", "minLength": 1 }
                }
              },
              "evidencePolicy": {
                "properties": {
                  "authorizedFieldUse": { "type": "array", "minItems": 1 }
                }
              },
              "provenanceRequirements": {
                "properties": {
                  "requiredFields": { "type": "array", "minItems": 1 }
                }
              },
              "refreshPolicy": {
                "properties": {
                  "mode": { "enum": ["scheduled", "manual"] },
                  "cadence": { "type": "string", "minLength": 1 }
                }
              },
              "remediation": {
                "properties": {
                  "correctionProcedure": { "type": "string", "minLength": 1 },
                  "retractionProcedure": { "type": "string", "minLength": 1 },
                  "removalProcedure": { "type": "string", "minLength": 1 },
                  "contactRole": { "type": "string", "minLength": 1 }
                }
              },
              "dataBoundary": {
                "properties": {
                  "permittedContent": { "type": "array", "minItems": 1 }
                }
              }
            }
          }
        }
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "aliases", "name", "publisher", "primaryUrl", "sourceType", "jurisdictions", "categoriesCovered"],
      "properties": {
        "sourceId": { "$ref": "#/$defs/nonEmptyString" },
        "aliases": { "$ref": "#/$defs/stringArray" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "publisher": { "$ref": "#/$defs/nullableString" },
        "primaryUrl": { "$ref": "#/$defs/nullableString" },
        "sourceType": {
          "type": "string",
          "enum": [
            "label",
            "regulator",
            "guideline",
            "manufacturer",
            "systematic-review",
            "paper",
            "review",
            "database",
            "clinical-trial-registry",
            "medical-summary",
            "forum",
            "social",
            "vendor-marketing",
            "internal-curation",
            "other"
          ]
        },
        "jurisdictions": { "$ref": "#/$defs/stringArray" },
        "categoriesCovered": { "$ref": "#/$defs/stringArray" }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewStatus",
        "legalBasisOrLicense",
        "termsUrl",
        "verifiedAtUtc",
        "allowedUses",
        "prohibitedUses",
        "redistributionConstraints",
        "reviewedByRole"
      ],
      "properties": {
        "reviewStatus": { "type": "string", "enum": ["pending-human-legal", "approved", "rejected"] },
        "legalBasisOrLicense": { "$ref": "#/$defs/nullableString" },
        "termsUrl": { "$ref": "#/$defs/nullableString" },
        "verifiedAtUtc": { "type": ["string", "null"], "format": "date-time" },
        "allowedUses": { "$ref": "#/$defs/stringArray" },
        "prohibitedUses": { "$ref": "#/$defs/stringArray" },
        "redistributionConstraints": { "$ref": "#/$defs/stringArray" },
        "reviewedByRole": { "$ref": "#/$defs/nullableString" }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "ownerRole", "securityOwnerRole", "lastReviewedAtUtc"],
      "properties": {
        "status": { "type": "string", "enum": ["disabled", "pending", "active", "retired"] },
        "ownerRole": { "$ref": "#/$defs/nullableString" },
        "securityOwnerRole": { "$ref": "#/$defs/nullableString" },
        "lastReviewedAtUtc": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "method",
        "hasApi",
        "hasBulkExport",
        "requiresAccount",
        "robotsPolicyStatus",
        "apiTermsStatus",
        "rateLimitPolicy",
        "accessNotes"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "method": { "type": "string", "enum": ["none", "api", "bulk-download", "manual-review", "licensed-feed", "other"] },
        "hasApi": { "type": "boolean" },
        "hasBulkExport": { "type": "boolean" },
        "requiresAccount": { "type": "boolean" },
        "robotsPolicyStatus": { "type": "string", "enum": ["not-reviewed", "approved", "restricted", "not-applicable"] },
        "apiTermsStatus": { "type": "string", "enum": ["not-reviewed", "approved", "restricted", "not-applicable"] },
        "rateLimitPolicy": { "$ref": "#/$defs/nullableString" },
        "accessNotes": { "$ref": "#/$defs/nullableString" }
      }
    },
    "evidencePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorityTier", "reliabilityScore", "authorizedFieldUse", "humanReviewRequirement", "limitations"],
      "properties": {
        "authorityTier": {
          "type": "string",
          "enum": ["A1", "A2", "B1", "B2", "B3", "B4", "C1", "C2", "D", "X"]
        },
        "reliabilityScore": { "type": "integer", "minimum": 0, "maximum": 5 },
        "authorizedFieldUse": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "identity",
              "regulatory",
              "approved-indications",
              "product-specific-dosing",
              "storage-reconstitution",
              "contraindications-warnings",
              "monitoring",
              "mechanism",
              "efficacy-claims",
              "interactions",
              "stack-heuristics",
              "popularity-signals",
              "misinformation-monitoring"
            ]
          },
          "uniqueItems": true
        },
        "humanReviewRequirement": {
          "type": "string",
          "enum": ["always", "high-risk-only", "before-canonical-promotion", "not-applicable"]
        },
        "limitations": { "$ref": "#/$defs/stringArray" }
      }
    },
    "provenanceRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredFields", "citationIdentifierTypes"],
      "properties": {
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "citationIdentifierTypes": { "$ref": "#/$defs/stringArray" }
      }
    },
    "refreshPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "cadence", "stalenessAction", "lastSuccessfulRefreshAtUtc"],
      "properties": {
        "mode": { "type": "string", "enum": ["disabled-until-approved", "scheduled", "manual", "retired"] },
        "cadence": { "$ref": "#/$defs/nullableString" },
        "stalenessAction": { "type": "string", "enum": ["block-use", "require-review", "warn", "not-applicable"] },
        "lastSuccessfulRefreshAtUtc": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correctionProcedure", "retractionProcedure", "removalProcedure", "contactRole"],
      "properties": {
        "correctionProcedure": { "$ref": "#/$defs/nonEmptyString" },
        "retractionProcedure": { "$ref": "#/$defs/nonEmptyString" },
        "removalProcedure": { "$ref": "#/$defs/nonEmptyString" },
        "contactRole": { "$ref": "#/$defs/nullableString" }
      }
    },
    "dataBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permittedContent",
        "restrictedContent",
        "privateDataAllowed",
        "copyrightedFullTextStorageAllowed",
        "trainingUseAllowed"
      ],
      "properties": {
        "permittedContent": { "$ref": "#/$defs/stringArray" },
        "restrictedContent": { "$ref": "#/$defs/stringArray" },
        "privateDataAllowed": { "type": "boolean" },
        "copyrightedFullTextStorageAllowed": { "type": "boolean" },
        "trainingUseAllowed": { "type": "boolean" }
      }
    }
  }
}
