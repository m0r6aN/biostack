<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="vendored-keon" value="packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- Clear Windows-specific Visual Studio fallback package folders so the Linux
       Docker container does not attempt to resolve paths that don't exist there. -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
