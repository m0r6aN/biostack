# BioStack Mission Control - Environment Configuration

# ── Backend ──────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
ConnectionStrings__DefaultConnection=Data Source=/app/data/biostack.db

# JWT (backend-issued tokens)
Jwt__Secret=CHANGE_ME_MINIMUM_32_CHARACTER_RANDOM_STRING
Jwt__Issuer=biostack
Jwt__Audience=biostack-ui
Jwt__ExpiryMinutes=60

# Shared secret between Next.js server and the API's /oauth-callback endpoint
Auth__CallbackSecret=CHANGE_ME_SHARED_SECRET

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NODE_ENV=development

# NextAuth v5
AUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_MIN_32_CHARS
AUTH_URL=http://localhost:3030

# Must match Auth__CallbackSecret above
AUTH_CALLBACK_SECRET=CHANGE_ME_SHARED_SECRET

# OAuth Provider Credentials — create apps in each provider's developer portal
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Docker / Hot Reload ───────────────────────────────────────────────────────
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
DOTNET_USE_POLLING_FILE_WATCHER=1
