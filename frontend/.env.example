# BioStack Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION: Copy to .env.local, fill every "Required" value, NEVER commit .env.local
# DEVELOPMENT: Copy to .env.local — defaults shown work for local Docker Compose dev setup.
# ─────────────────────────────────────────────────────────────────────────────

# ── API endpoints ─────────────────────────────────────────────────────────────
# Public URL — used in browser-side fetch calls (must be reachable from user's browser)
NEXT_PUBLIC_API_URL=http://localhost:5000
# Internal URL — used in Next.js server-side routes (e.g. API route handlers)
API_INTERNAL_URL=http://localhost:5000

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=                          # Required. Min 32 random chars.
AUTH_URL=http://localhost:3043        # Required. Full public URL of this frontend.
AUTH_TRUST_HOST=true

# Must match the backend's Auth__CallbackSecret environment variable
AUTH_CALLBACK_SECRET=                 # Required.

# ── Research data source ──────────────────────────────────────────────────────
# "fixtures" — serve local JSON files from src/fixtures/research/ (safe for dev)
# "api"      — fetch from real backend (requires backend running with knowledge worker seeded)
RESEARCH_DATA_SOURCE=fixtures

# Path to the knowledge-worker output directory (only used when RESEARCH_DATA_SOURCE=api)
# RESEARCH_ARTIFACTS_PATH=research/output/<run-id>
