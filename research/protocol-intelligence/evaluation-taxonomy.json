      "id": "allowed",
      "description": "Existing runtime SafetyStatus value; no safety rewrite is required."
    },
    {
      "id": "constrained",
      "description": "Existing runtime SafetyStatus value; output is neutralized or narrowed."
    },
    {
      "id": "refused",
      "description": "Existing runtime SafetyStatus value; the unsafe request is refused."
    },
    {
      "id": "warning",
      "description": "Existing runtime SafetyStatus value; warning-first framing is required."
