      "id": "supported",
      "description": "The request is within the declared evaluation coverage contract."
    },
    {
      "id": "unknown",
      "description": "Available evidence or input is insufficient to classify an answer; this is not a safety status."
    },
    {
      "id": "unsupported",
      "description": "The request is outside the declared product or communication coverage."
    }
  ],
